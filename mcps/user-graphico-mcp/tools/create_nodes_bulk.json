{
  "name": "create_nodes_bulk",
  "description": "Create multiple graph nodes in one request. Returns JSON with `ids` in the same order as the input.",
  "arguments": {
    "type": "object",
    "properties": {
      "nodes": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "color": {
              "type": [
                "string",
                "null"
              ]
            },
            "data": {
              "default": "",
              "type": "string"
            },
            "edges": {
              "description": "Neighbor node UUIDs (strings accepted by the HTTP API).",
              "items": {
                "type": "string"
              },
              "type": [
                "array",
                "null"
              ]
            },
            "name": {
              "type": "string"
            },
            "position": {
              "$ref": "#/$defs/Coordinates"
            }
          },
          "required": [
            "name",
            "position"
          ]
        }
      }
    },
    "required": [
      "nodes"
    ],
    "$defs": {
      "Coordinates": {
        "properties": {
          "x": {
            "format": "float",
            "type": "number"
          },
          "y": {
            "format": "float",
            "type": "number"
          }
        },
        "required": [
          "x",
          "y"
        ],
        "type": "object"
      }
    },
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "GraphicoCreateNodesBulkArgs"
  }
}
